<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#2D1A5C"
    android:paddingHorizontal="24dp"
    android:paddingTop="8dp"
    android:paddingBottom="20dp">

    <!-- New Password label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="NEW PASSWORD"
        android:textColor="#B292E7"
        android:textSize="11sp"
        android:letterSpacing="0.1"
        android:layout_marginBottom="6dp" />

    <!-- New Password field row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/auth_input_background"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/etNewPassword"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@null"
            android:textColor="#E6DCF6"
            android:textSize="15sp"
            android:inputType="textPassword"
            android:hint="Enter new password"
            android:textColorHint="#9F8FBC" />

        <ImageView
            android:id="@+id/btnToggleNew"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_eye_open"
            android:tint="#9F8FBC"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Toggle password visibility" />
    </LinearLayout>

    <!-- Confirm Password label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CONFIRM PASSWORD"
        android:textColor="#B292E7"
        android:textSize="11sp"
        android:letterSpacing="0.1"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="6dp" />

    <!-- Confirm Password field row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/auth_input_background"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/etConfirmPassword"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@null"
            android:textColor="#E6DCF6"
            android:textSize="15sp"
            android:inputType="textPassword"
            android:hint="Confirm new password"
            android:textColorHint="#9F8FBC" />

        <ImageView
            android:id="@+id/btnToggleConfirm"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_eye_open"
            android:tint="#9F8FBC"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Toggle password visibility" />
    </LinearLayout>

</LinearLayout>
