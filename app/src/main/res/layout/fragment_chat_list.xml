<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#21103E">

    <!-- Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Messages"
        android:textColor="#E6DCF6"
        android:textSize="22sp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:paddingTop="28dp"
        android:paddingBottom="12dp" />

    <!-- Filter toggle -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="12dp"
        android:background="@drawable/chat_item_bg"
        android:orientation="horizontal"
        android:padding="4dp">

        <TextView
            android:id="@+id/tabBuying"
            android:layout_width="120dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="Buying"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/filter_tab_active_bg"
            android:textColor="#FFFFFF"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/tabSelling"
            android:layout_width="120dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="Selling"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/filter_tab_inactive_bg"
            android:textColor="#9F8FBC"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/llNoChats"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_chat"
            android:alpha="0.3"
            android:tint="#B292E7" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No chats yet"
            android:textColor="#E6DCF6"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginTop="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap Chat on any listing to start a conversation"
            android:textColor="#9F8FBC"
            android:textSize="13sp"
            android:gravity="center"
            android:paddingHorizontal="48dp"
            android:layout_marginTop="8dp" />
    </LinearLayout>

    <!-- Sign-in required state -->
    <LinearLayout
        android:id="@+id/llSignInChats"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_account_outline"
            android:alpha="0.3"
            android:tint="#B292E7" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sign in to view your chats"
            android:textColor="#E6DCF6"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginTop="16dp" />
    </LinearLayout>

    <!-- Active chats -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChats"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp"
        android:visibility="gone" />

    <!-- Archived section toggle -->
    <TextView
        android:id="@+id/tvArchivedToggle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingVertical="14dp"
        android:textColor="#9F8FBC"
        android:textSize="13sp"
        android:visibility="gone"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvArchivedChats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone" />

</LinearLayout>
