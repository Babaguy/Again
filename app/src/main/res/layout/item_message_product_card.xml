<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="8dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/card_product_bg"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="24dp"
        android:paddingVertical="16dp"
        android:minWidth="200dp">

        <!-- Shopping bag icon -->
        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_ad"
            android:tint="#B292E7"
            android:layout_marginBottom="8dp" />

        <!-- Product name -->
        <TextView
            android:id="@+id/tvCardTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#E6DCF6"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:maxLines="2"
            android:ellipsize="end" />

        <!-- Price -->
        <TextView
            android:id="@+id/tvCardPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#B292E7"
            android:textSize="17sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginTop="4dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#8361C5"
            android:alpha="0.3"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="8dp" />

        <!-- "I'm interested" hint -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="I'm interested"
            android:textColor="#9F8FBC"
            android:textSize="12sp"
            android:fontFamily="sans-serif-light" />

    </LinearLayout>

</FrameLayout>
